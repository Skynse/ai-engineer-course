---
import BaseLayout from '../layouts/BaseLayout.astro';
import { course } from '../lib/course';

const firstLesson = course.lessons[0];
---

<BaseLayout title={course.title}>
  <main class="page">
    <section style="display:flex;justify-content:space-between;gap:24px;align-items:flex-end;margin-bottom:36px;flex-wrap:wrap;">
      <div>
        <div class="eyebrow">Static Course Preview</div>
        <h1 class="hero-title">{course.title}</h1>
        <p class="hero-copy">{course.subtitle}</p>
        <p class="eyebrow" style="margin-top:22px;">{course.lessons.length} released lessons across {course.modules.length} chapters</p>
      </div>

      {firstLesson && (
        <a
          href={`/lessons/${firstLesson.slug}/`}
          style="display:inline-flex;align-items:center;justify-content:center;height:58px;padding:0 28px;border-radius:999px;background:#f3f4f6;color:#111827;font-weight:700;"
        >
          Continue
        </a>
      )}
    </section>

    <section class="grid-main">
      <div>
        {course.modules.map((module) => (
          <article class="panel module-card">
            <div class="module-header">
              <div>
                <div class="module-code">{module.code}</div>
                <h2 class="module-title" style="margin-top:16px;">{module.title}</h2>
                <p class="module-desc">{module.description}</p>
              </div>
              {module.image && (
                <div class="module-media">
                  <img src={module.image} alt={module.title} />
                </div>
              )}
              <div class="eyebrow">{module.lessons.length} lessons</div>
            </div>

            <div class="lesson-list">
              {module.lessons.map((lesson) => (
                <a class="lesson-row" href={`/lessons/${lesson.slug}/`}>
                  <div class="lesson-meta">
                    <span class="lesson-number">{lesson.number}</span>
                    <span class="lesson-title">{lesson.title}</span>
                  </div>
                  <span class="lesson-arrow">Open →</span>
                </a>
              ))}
            </div>
          </article>
        ))}
      </div>

      <aside style="display:grid;gap:18px;">
        <section class="panel side-note">
          <h3>How chapters work</h3>
          <p>
            This shell keeps the content static, but organizes the markdown lessons
            into a course-platform style hierarchy your team can hand off to a real product.
          </p>
        </section>

        <section class="panel side-note">
          <h3>What this proves</h3>
          <p>
            The source content can stay in markdown while the frontend becomes a
            polished syllabus and lesson-reading experience with chapters, navigation,
            linked media, and course framing.
          </p>
        </section>
      </aside>
    </section>
  </main>
</BaseLayout>
